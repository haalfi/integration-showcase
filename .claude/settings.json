{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-init.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/gate-commit.sh"
          },
          {
            "type": "command",
            "if": "Bash(git push*)",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/gate-push.sh"
          },
          {
            "type": "command",
            "if": "Bash(pytest*)",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/deny-bare-runner.sh 'pytest → hatch run test'"
          },
          {
            "type": "command",
            "if": "Bash(ruff*)",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/deny-bare-runner.sh 'ruff → hatch run lint'"
          },
          {
            "type": "command",
            "if": "Bash(mypy*)",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/deny-bare-runner.sh 'mypy → hatch run typecheck'"
          },
          {
            "type": "command",
            "if": "Bash(sed*)",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/deny-bare-runner.sh 'sed → use Read tool with offset/limit'"
          },
          {
            "type": "command",
            "if": "Bash(cat*)",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/deny-bare-runner.sh 'cat → use Read tool'"
          },
          {
            "type": "command",
            "if": "Bash(head*)",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/deny-bare-runner.sh 'head → use Read tool with limit'"
          },
          {
            "type": "command",
            "if": "Bash(tail*)",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/deny-bare-runner.sh 'tail → use Read tool (read full file or use offset+limit)'"
          },
          {
            "type": "command",
            "if": "Bash(awk*)",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/deny-bare-runner.sh 'awk → use Read/Grep tools'"
          },
          {
            "type": "command",
            "if": "Bash(find*)",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/deny-bare-runner.sh 'find → use Glob tool'"
          },
          {
            "type": "command",
            "if": "Bash(grep*)",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/deny-bare-runner.sh 'grep → use Grep tool'"
          },
          {
            "type": "command",
            "if": "Bash(echo*)",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/deny-bare-runner.sh 'echo → output text directly or use Write tool'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/ruff-format.sh"
          }
        ]
      }
    ]
  }
}
